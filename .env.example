# Arquivo de configuração — copie para .env e preencha com seus dados

# ── Banco de Dados PostgreSQL (Supabase ou local) ──────────────────────────
DATABASE_URL=postgresql://usuario:senha@host:5432/prospeccao

# ── Scraper — Brasil.io (dados públicos da Receita Federal) ────────────────
# Cadastre-se GRÁTIS em https://brasil.io/auth/entrar/ e gere seu token
BRASIL_IO_TOKEN=seu_token_brasil_io_aqui

# ── Ollama (IA local) ───────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Ritmo do Agente (24h/dia constante) ────────────────────────────────────
# Tempo de espera em milissegundos quando a fila está VAZIA (padrão: 60s)
RITMO_CONSTANTE_MS=60000

# ── Obsidian Vault — pasta onde os .md serão salvos automaticamente ─────────
# Exemplo Windows:
OBSIDIAN_VAULT_PATH=C:/Users/marco/OneDrive/Documentos/Obsidian/Vault/Leads
# Exemplo macOS/Linux:
# OBSIDIAN_VAULT_PATH=/Users/marco/Documents/Obsidian/Vault/Leads
